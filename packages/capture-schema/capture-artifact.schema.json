{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ddouns.local/apple-glass-parity/capture-artifact.schema.json",
  "title": "Apple Glass Parity CaptureArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "rig_id",
    "scene_id",
    "state_id",
    "git_commit",
    "capture_kind",
    "device_info",
    "environment",
    "color",
    "frame_pack",
    "integrity"
  ],
  "properties": {
    "schema_version": { "const": "1.2.0" },
    "id": { "type": "string", "minLength": 1 },
    "rig_id": { "enum": ["R0", "R1", "C0", "C1", "DOM_C", "DX_REPLAY"] },
    "scene_id": {
      "enum": [
        "S00_NULL",
        "S01_SEARCH",
        "S02_LOUPE",
        "S03_PRESS",
        "S04_MORPH",
        "S05_FLOATING_BAR",
        "S06_TINY_GLASS",
        "S07_BUSY_PHOTO",
        "S08_P3_GRADIENT",
        "S09_NEAR_WHITE",
        "S10_NEAR_BLACK",
        "S11_VIDEO_FRAME",
        "S12_SYSTEM_MATERIAL_ADJACENCY"
      ]
    },
    "state_id": { "type": "string", "minLength": 1 },
    "git_commit": { "type": "string", "minLength": 1 },
    "technical_class": { "enum": ["SWIFTUI_PASS", "WEBKIT_PASS", "SHADER_PASS", "FAIL", "INVALID"] },
    "verdict_class": {
      "enum": [
        "TECH_PASS_PENDING_SIGNOFF",
        "PASS_WITH_REVIEW",
        "PROD_PASS",
        "BLOCKED_FOR_DESIGN",
        "LEGIBILITY_BLOCK",
        "FAIL",
        "INVALID"
      ]
    },
    "flake_class": { "enum": ["NONE", "INFRA_FLAKE", "PRODUCT_REGRESSION", "METRIC_NOISE", "UNKNOWN"] },
    "null_qualification": { "enum": ["pass", "fail"] },
    "invalid_reason": { "type": "string" },
    "capture_kind": { "enum": ["compositor", "framebuffer", "layer_snapshot"] },
    "device_info": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model_name",
        "model_identifier",
        "os_name",
        "os_version",
        "os_build",
        "sdk_build",
        "screen_scale",
        "refresh_hz",
        "thermal_state_start",
        "low_power_mode"
      ],
      "properties": {
        "model_name": { "type": "string", "minLength": 1 },
        "model_identifier": { "type": "string", "minLength": 1 },
        "device_matrix_role": { "enum": ["mvl_primary", "weakest_supported", "target", "latest_pro"] },
        "os_name": { "const": "iOS" },
        "os_version": { "type": "string", "minLength": 1 },
        "os_build": { "type": "string", "minLength": 1 },
        "sdk_build": { "type": "string", "minLength": 1 },
        "screen_scale": { "type": "number", "exclusiveMinimum": 0 },
        "refresh_hz": { "type": "number", "exclusiveMinimum": 0 },
        "thermal_state_start": { "enum": ["nominal", "fair", "serious", "critical"] },
        "thermal_state_end": { "enum": ["nominal", "fair", "serious", "critical"] },
        "low_power_mode": { "type": "boolean" }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appearance",
        "reduce_transparency",
        "reduce_motion",
        "viewport_px",
        "capture_timestamp_ns"
      ],
      "properties": {
        "appearance": { "enum": ["light", "dark"] },
        "reduce_transparency": { "type": "boolean" },
        "reduce_motion": { "type": "boolean" },
        "content_seed": { "type": "string" },
        "background_asset_hash": { "type": "string" },
        "background_pack_id": { "type": "string", "minLength": 1 },
        "background_id": { "type": "string", "minLength": 1 },
        "background_pack_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "geometry_pack_id": { "type": "string", "minLength": 1 },
        "geometry_id": { "type": "string", "minLength": 1 },
        "geometry_pack_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "viewport_px": {
          "type": "object",
          "additionalProperties": false,
          "required": ["width", "height"],
          "properties": {
            "width": { "type": "integer", "exclusiveMinimum": 0 },
            "height": { "type": "integer", "exclusiveMinimum": 0 }
          }
        },
        "capture_timestamp_ns": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["content_seed"] },
        { "required": ["background_asset_hash"] }
      ]
    },
    "color": {
      "type": "object",
      "additionalProperties": false,
      "required": ["embedded_icc_profile", "icc_sha256", "working_space", "stored_transfer", "white_point"],
      "properties": {
        "embedded_icc_profile": { "const": "Display P3" },
        "icc_sha256": { "type": "string", "minLength": 1 },
        "working_space": { "const": "display-p3-linear" },
        "stored_transfer": { "const": "srgb-transfer" },
        "white_point": { "const": "D65" }
      }
    },
    "frame_pack": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_png_sha256",
        "base_png_path",
        "mask_pack_sha256",
        "mask_pack_path",
        "touch_phase",
        "animation_t"
      ],
      "properties": {
        "base_png_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "base_png_path": { "type": "string", "minLength": 1 },
        "sequence_paths": { "type": "array", "items": { "type": "string" } },
        "sequence_timestamps_ms": { "type": "array", "items": { "type": "number" } },
        "mask_pack_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "mask_pack_path": { "type": "string", "minLength": 1 },
        "touch_phase": { "enum": ["rest", "press", "drag", "release", "morph", "sustained"] },
        "animation_t": { "type": "number" },
        "sustained_duration_ms": { "type": "number", "minimum": 0 },
        "trajectory_source_sha256": { "type": "string", "minLength": 64, "maxLength": 64 },
        "capture_timeline_pack_id": { "type": "string", "minLength": 1 },
        "capture_timeline_id": { "type": "string", "minLength": 1 },
        "capture_timeline_sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
      }
    },
    "shader": { "type": "object" },
    "perf": {
      "type": "object",
      "properties": {
        "measurement_source": { "type": "string" },
        "cpu_frame_ms_p95": { "type": "number" },
        "gpu_frame_ms_p95": { "type": "number" },
        "compositor_frame_ms_p95": { "type": "number" },
        "full_frame_ms_p95": { "type": "number" },
        "frame_interval_ms_p95": { "type": "number" },
        "dropped_frames": { "type": "number" },
        "sustained_degradation_pct": { "type": "number" },
        "memory_mb_p95": { "type": "number" },
        "refresh_budget_ms": { "type": "number" }
      }
    },
    "energy": {
      "type": "object",
      "required": ["trace_available"],
      "properties": {
        "trace_available": { "type": "boolean" },
        "trace_status": { "enum": ["available", "trace_unavailable"] },
        "measurement_source": { "type": "string" },
        "trace_tool": { "enum": ["instruments_power_profiler", "metrickit", "validated_powermetrics_aux"] },
        "trace_path": { "type": "string", "minLength": 1 },
        "trace_hash_method": { "enum": ["sha256_file_v1", "sha256_tree_v1"] },
        "trace_sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "energy_mj_per_10s": { "type": "number" },
        "average_power_mw": { "type": "number" },
        "thermal_onset_ms": { "type": "number" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "trace_available": { "const": true } },
            "required": ["trace_available"]
          },
          "then": {
            "required": ["trace_status", "trace_tool", "trace_path", "trace_hash_method", "trace_sha256"],
            "properties": { "trace_status": { "const": "available" } }
          }
        },
        {
          "if": {
            "properties": { "trace_available": { "const": false } },
            "required": ["trace_available"]
          },
          "then": {
            "not": {
              "properties": { "trace_status": { "const": "available" } },
              "required": ["trace_status"]
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "properties": {
        "g7_status": { "enum": ["not_run", "passed", "pass_with_review", "blocked_for_design", "legibility_block"] },
        "design_class": { "enum": ["NOT_RUN", "PASS", "PASS_WITH_REVIEW", "BLOCKED_FOR_DESIGN", "LEGIBILITY_BLOCK"] },
        "design_reviewer": { "type": "string" },
        "product_reviewer": { "type": "string" },
        "owner_decision": { "enum": ["prod_pass", "pass_with_review", "blocked_for_design", "legibility_block"] },
        "review_packet_sha256": { "type": "string" },
        "g7_report_sha256": { "type": "string" },
        "g8_report_sha256": { "type": "string" },
        "comments_sha256": { "type": "string" }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_sha256", "producer_version"],
      "properties": {
        "artifact_sha256": { "type": "string", "pattern": "^[0-9a-fA-F]{64}$" },
        "artifact_hash_method": { "enum": ["canonical_json_zeroed_integrity_v1"] },
        "producer_version": { "type": "string", "minLength": 1 }
      }
    }
  }
}
