{
  "name": "liquid-glass-capture-expo",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --dev-client",
    "typecheck": "tsc --noEmit",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:production": "eas build --profile production --platform ios",
    "build:android:dev": "eas build --profile development --platform android",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:android:production": "eas build --profile production --platform android",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "expo": "56.0.12",
    "expo-build-properties": "56.0.19",
    "expo-dev-client": "56.0.20",
    "expo-modules-core": "56.0.17",
    "liquid-glass-capture": "file:modules/liquid-glass-capture",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@types/react": "19.2.17",
    "eas-cli": "^20.3.0",
    "typescript": "~6.0.3"
  }
}
