{
  "name": "liquid-glass-capture-expo",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start --dev-client",
    "typecheck": "tsc --noEmit",
    "schema:build": "node scripts/lab-schema-build.mjs",
    "artifact:validate": "node scripts/lab-artifact-validate.mjs",
    "color:normalize": "node scripts/lab-color-normalize.mjs",
    "glass:diff": "node scripts/lab-glass-diff.mjs",
    "glass:inspect": "node scripts/lab-glass-inspect.mjs",
    "ios:capture": "node scripts/lab-ios-capture.mjs",
    "metrics:compare": "node scripts/lab-metrics-compare.mjs",
    "metrics:baseline": "node scripts/lab-metrics-baseline.mjs",
    "null:ladder": "node scripts/lab-null-ladder.mjs",
    "lab:self-test": "npm run schema:build && node scripts/lab-artifact-validate.mjs --self-test && node scripts/lab-null-ladder.mjs --self-test && node scripts/lab-color-normalize.mjs --self-test && node scripts/lab-ios-capture.mjs --self-test && node scripts/lab-metrics-compare.mjs --self-test && node scripts/lab-metrics-baseline.mjs --self-test && node scripts/lab-glass-inspect.mjs --self-test && node scripts/lab-glass-diff.mjs --self-test",
    "prebuild:ios": "expo prebuild --platform ios",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:production": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "expo": "56.0.12",
    "expo-build-properties": "56.0.19",
    "expo-dev-client": "56.0.20",
    "expo-modules-core": "56.0.17",
    "liquid-glass-capture": "file:modules/liquid-glass-capture",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@types/react": "19.2.17",
    "eas-cli": "^20.3.0",
    "typescript": "~6.0.3"
  }
}
